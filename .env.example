# Server Configuration
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
ENV=development
LOG_LEVEL=debug
# Cookie domain for admin SPA HttpOnly auth cookies. Empty = host-only (the
# cookie is locked to the exact host that issued it). Set to e.g.
# ".hamsaya.af" only when admin panel and API live on different subdomains.
ADMIN_COOKIE_DOMAIN=

# Database Configuration
# Use DB_PORT=5433 when Postgres runs via Docker (host port mapping in docker-compose)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=hamsaya
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL_MODE=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=30m

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=devredispass
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_TOKEN_DURATION=15m
# Sliding refresh window. Each /auth/refresh re-issues with full TTL, so an
# active user effectively never gets logged out. Combined with device
# credentials (/auth/device/login), idle users beyond this window can also
# silently re-establish a session.
JWT_REFRESH_TOKEN_DURATION=2160h
# How long a rotated refresh token is still accepted (idempotent rotation).
# Concurrent /auth/refresh calls from the same client (multiple isolates,
# proactive timer + 401 retry) get the same new token pair. Out-of-grace
# reuse triggers reuse-detection and revokes the whole session family.
JWT_REFRESH_GRACE=60s
# Device credential lifetime. Long-lived secret stored in iOS Keychain /
# Android Keystore; exchanged at /auth/device/login for a fresh token pair
# when the refresh token is past its window. 4320h = 180d (forces re-login
# every 6 months even on always-online devices). 0 = non-expiring (NOT
# RECOMMENDED — leaves a stolen credential valid indefinitely until manual
# revoke).
DEVICE_CREDENTIAL_DURATION=4320h

# At-rest encryption key for MFA TOTP secrets. 32 bytes hex encoded (64 chars).
# Generate with: openssl rand -hex 32
# When unset, MFA secrets are stored plaintext (legacy / dev only — non-compliant for prod).
MFA_SECRET_ENCRYPTION_KEY=

# OAuth Configuration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Storage Configuration (MinIO/S3)
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET_NAME=hamsaya-uploads
STORAGE_USE_SSL=false
STORAGE_REGION=us-east-1
# URL returned to clients for uploaded files. Use localhost only for same-machine testing.
# When the app (e.g. Flutter) runs on a device, set this to a URL the device can reach, e.g.:
# CDN_URL=http://YOUR_MACHINE_IP:9000
CDN_URL=http://localhost:9000

# Firebase Configuration (for push notifications — Android)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CREDENTIALS_PATH=

# APNs Configuration (iOS push — direct to Apple, bypasses Google/FCM).
# Required so iOS push works in Afghanistan where Google endpoints are blocked.
# APNS_KEY_P8 accepts a raw PEM, a single-line PEM with literal \n escapes, or a
# base64-encoded PEM blob (Dokploy-safe). Get the .p8 from Apple Developer →
# Keys → Apple Push Notifications service (APNs). Set APNS_PRODUCTION=true for
# App Store/TestFlight builds (the gateway is auto-retried on mismatch anyway).
APNS_KEY_P8=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=af.hamsaya
APNS_PRODUCTION=true

# In-app update gate (backend-driven; works where Google Play / iTunes are
# blocked). The app compares its own build number against these. Below MIN =
# forced (blocking) update; below LATEST = soft dismissible prompt. Leave 0 to
# disable. Bump on each release.
APP_MIN_BUILD_IOS=0
APP_LATEST_BUILD_IOS=0
APP_MIN_BUILD_ANDROID=0
APP_LATEST_BUILD_ANDROID=0
APP_STORE_URL_IOS=https://apps.apple.com/app/idXXXXXXXXX
APP_STORE_URL_ANDROID=https://play.google.com/store/apps/details?id=af.hamsaya

# Geocoding Configuration
GEOCODING_API_KEY=
GEOCODING_PROVIDER=google

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_HOUR=1000
RATE_LIMIT_AUTH_ATTEMPTS=5
RATE_LIMIT_AUTH_WINDOW=15m

# Email Configuration (verification, welcome, password reset)
# At least one of Resend or SMTP must be set for verification emails to be sent.
# Option A: Resend. Get API key at https://resend.com. Verify your domain in Resend dashboard, then set:
RESEND_API_KEY=re_your_resend_api_key_here
# From address MUST use a verified domain so Resend delivers to all recipients.
# If empty, uses onboarding@resend.dev (sandbox: only delivers to your Resend account email).
EMAIL_FROM=Hamsaya <noreply@yourdomain.com>
# Option B: SMTP (e.g. Gmail, SendGrid SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# CORS Configuration
# Include admin panel URLs for development and production
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://admin.hamsaya.app
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization
CORS_ALLOW_CREDENTIALS=true

# Monitoring
SENTRY_DSN=

# In-app OpenTelemetry / Prometheus metrics. Keep FALSE unless you actually run
# a Prometheus + Grafana stack to scrape them — when enabled the API holds every
# HTTP metric series in memory, which is wasted RAM (and was a cardinality leak)
# if nothing scrapes it. Infra metrics (CPU/mem/disk) are already covered by the
# Beszel agent, so this stays off in production. OTLP_ENDPOINT empty = no tracing.
OBSERVABILITY_ENABLED=false
OTLP_ENDPOINT=
# (PROMETHEUS_ENABLED is unused — the code reads OBSERVABILITY_ENABLED.)

# Database backups. BACKUP_PASSPHRASE encrypts each pg_dump via gpg before
# the file ever lands on disk; rotate it like any other secret. Without a
# passphrase the daily backup job logs an error and refuses to run so
# unencrypted dumps never persist.
BACKUP_ENABLED=true
BACKUP_PASSPHRASE=
BACKUP_LOCAL_DIR=/var/lib/hamsaya/backups
BACKUP_BUCKET=hamsaya-backups

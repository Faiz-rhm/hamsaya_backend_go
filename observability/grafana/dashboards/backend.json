{
  "title": "Hamsaya Backend",
  "uid": "hamsaya-backend",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "tags": ["hamsaya", "backend"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requests / sec",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(rate(http_requests_total[1m]))", "legendFormat": "rps" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "5xx error rate",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m])) * 100",
          "legendFormat": "%"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active WS connections",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "websocket_connections_active", "legendFormat": "ws" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "In-flight requests",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "http_server_active_requests", "legendFormat": "in-flight" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP request rate by status",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (status_code) (rate(http_requests_total[1m]))",
          "legendFormat": "{{status_code}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Request duration p50 / p95 / p99",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Posts created (by type)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (type) (rate(posts_created_total[5m]))",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Users + messages created",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(users_created_total[5m]))",
          "legendFormat": "users/s"
        },
        {
          "expr": "sum(rate(messages_created_total[5m]))",
          "legendFormat": "messages/s"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "DB queries by operation",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (operation) (rate(db_queries_total[1m]))",
          "legendFormat": "{{operation}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "DB query latency p50 / p95 / p99",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(db_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(db_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(db_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "DB query rate by table (top 10)",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "topk(10, sum by (table) (rate(db_queries_total[5m])))",
          "legendFormat": "{{table}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "stat",
      "title": "DB error rate (1m)",
      "gridPos": { "x": 0, "y": 36, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(db_queries_total{success=\"false\"}[1m])) / sum(rate(db_queries_total[1m])) * 100",
          "legendFormat": "%"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    }
  ]
}
